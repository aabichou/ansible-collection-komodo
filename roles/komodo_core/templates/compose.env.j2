# Managed by Ansible — do not edit manually.
# Source: roles/komodo_core/templates/compose.env.j2

####################################
# 🦎 KOMODO COMPOSE - VARIABLES 🦎 #
####################################

# ── Database credentials ──────────────────────────────────────────────────
KOMODO_DATABASE_USERNAME={{ komodo_db_username }}
KOMODO_DATABASE_PASSWORD={{ komodo_db_password }}
KOMODO_DATABASE_DB_NAME={{ komodo_db_name }}

# ── Core settings ─────────────────────────────────────────────────────────
KOMODO_HOST={{ komodo_core_public_url }}
KOMODO_TITLE={{ komodo_title }}
TZ={{ komodo_timezone }}

{% if komodo_first_server_address or komodo_first_server_name != 'Local' %}
# Auto-register first periphery on startup.
# If only KOMODO_FIRST_SERVER_NAME is set (no ADDRESS), Core assumes outbound Periphery mode.
{% if komodo_first_server_address %}
KOMODO_FIRST_SERVER_ADDRESS={{ komodo_first_server_address }}
{% endif %}
KOMODO_FIRST_SERVER_NAME={{ komodo_first_server_name }}
{% endif %}

KOMODO_DISABLE_CONFIRM_DIALOG={{ komodo_disable_confirm_dialog | lower }}
KOMODO_DISABLE_INIT_RESOURCES={{ komodo_disable_init_resources | lower }}

# ── v2 PKI auth ───────────────────────────────────────────────────────────
# Core and Periphery authenticate via the Noise protocol (auto-generated key pairs).
# Optionally pin which Periphery public key Core will accept.
# Leave empty to accept any Periphery (rely on network/NSG security instead).
{% if komodo_periphery_public_key %}
KOMODO_PERIPHERY_PUBLIC_KEY={{ komodo_periphery_public_key }}
{% endif %}

# ── Poll intervals ────────────────────────────────────────────────────────
# Options: 1-sec, 5-sec, 15-sec, 1-min, 5-min, 15-min
KOMODO_MONITORING_INTERVAL={{ komodo_monitoring_interval }}
# Options: 15-min, 1-hr, 2-hr, 6-hr, 12-hr, 1-day
KOMODO_RESOURCE_POLL_INTERVAL={{ komodo_resource_poll_interval }}

# ── Secrets ───────────────────────────────────────────────────────────────
KOMODO_WEBHOOK_SECRET={{ komodo_webhook_secret }}
KOMODO_JWT_SECRET={{ komodo_jwt_secret }}
# Options: 1-hr, 12-hr, 1-day, 3-day, 1-wk, 2-wk
KOMODO_JWT_TTL={{ komodo_jwt_ttl }}

# ── Local auth ────────────────────────────────────────────────────────────
KOMODO_LOCAL_AUTH={{ komodo_local_auth | lower }}
KOMODO_INIT_ADMIN_USERNAME={{ komodo_init_admin_username }}
KOMODO_INIT_ADMIN_PASSWORD={{ komodo_init_admin_password }}
KOMODO_DISABLE_USER_REGISTRATION={{ komodo_disable_user_registration | lower }}
KOMODO_ENABLE_NEW_USERS={{ komodo_enable_new_users | lower }}
KOMODO_DISABLE_NON_ADMIN_CREATE={{ komodo_disable_non_admin_create | lower }}
KOMODO_TRANSPARENT_MODE={{ komodo_transparent_mode | lower }}

# ── OIDC ──────────────────────────────────────────────────────────────────
KOMODO_OIDC_ENABLED={{ komodo_oidc_enabled | lower }}
{% if komodo_oidc_enabled %}
KOMODO_OIDC_PROVIDER={{ komodo_oidc_provider }}
KOMODO_OIDC_REDIRECT_HOST={{ komodo_oidc_redirect_host }}
KOMODO_OIDC_CLIENT_ID={{ komodo_oidc_client_id }}
KOMODO_OIDC_CLIENT_SECRET={{ komodo_oidc_client_secret }}
KOMODO_OIDC_USE_FULL_EMAIL={{ komodo_oidc_use_full_email | lower }}
{% endif %}

# ── GitHub OAuth ──────────────────────────────────────────────────────────
KOMODO_GITHUB_OAUTH_ENABLED={{ komodo_github_oauth_enabled | lower }}
{% if komodo_github_oauth_enabled %}
KOMODO_GITHUB_OAUTH_ID={{ komodo_github_oauth_id }}
KOMODO_GITHUB_OAUTH_SECRET={{ komodo_github_oauth_secret }}
{% endif %}

# ── Google OAuth ──────────────────────────────────────────────────────────
KOMODO_GOOGLE_OAUTH_ENABLED={{ komodo_google_oauth_enabled | lower }}
{% if komodo_google_oauth_enabled %}
KOMODO_GOOGLE_OAUTH_ID={{ komodo_google_oauth_id }}
KOMODO_GOOGLE_OAUTH_SECRET={{ komodo_google_oauth_secret }}
{% endif %}

# ── Logging ───────────────────────────────────────────────────────────────
KOMODO_LOGGING_LEVEL={{ komodo_logging_level }}
KOMODO_LOGGING_PRETTY={{ komodo_logging_pretty | lower }}
KOMODO_PRETTY_STARTUP_CONFIG={{ komodo_pretty_startup_config | lower }}

# ── Pruning ────────────────────────────────────────────────────────
KOMODO_KEEP_STATS_FOR_DAYS={{ komodo_keep_stats_for_days }}
KOMODO_KEEP_ALERTS_FOR_DAYS={{ komodo_keep_alerts_for_days }}

{% if komodo_core_containerized_periphery | default(false) %}
# ── Containerised Periphery (enabled via komodo_core_containerized_periphery) ───
PERIPHERY_ROOT_DIRECTORY=/etc/komodo
PERIPHERY_CORE_PUBLIC_KEYS=file:/config/keys/core.pub
PERIPHERY_INCLUDE_DISK_MOUNTS=/etc/hostname
{% endif %}
